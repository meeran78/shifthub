{
  "name": "@shifthub/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:push:force": "prisma db push --accept-data-loss",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
